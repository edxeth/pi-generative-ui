{
  "name": "pi-generative-ui",
  "version": "0.2.0",
  "description": "Generative UI for pi — render interactive HTML/SVG widgets in native Glimpse windows on macOS and Linux",
  "type": "commonjs",
  "keywords": ["pi-package"],
  "files": [
